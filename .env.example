# --- App ---
ENV=development
LOG_LEVEL=INFO
LOG_JSON=false
CAMPAIGN_DEMO_MODE=false

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///campaign_v2.db

# --- Queue (Phase 4+) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
ANTHROPIC_API_KEY=
LLM_SYNTHESIS_MODEL=claude-opus-4-8
LLM_EXTRACTION_MODEL=claude-sonnet-5
LLM_PROMPT_CACHE=true

# --- EA integration (defaults; per-persona override in DB) ---
EA_ENABLED_DEFAULT=false
EA_EMAIL_DEFAULT=
